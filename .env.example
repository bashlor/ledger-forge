# Tenant mode: 'multi' (default) or 'single' (recommended for single-VPS deploy)
TENANT_MODE=multi
# Set SINGLE_TENANT_ORG_ID when TENANT_MODE=single.

# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=5162206c63cca8cd8cb79319cf53b2f7 # CHANGE ME PLS !!!!!
APP_URL=http://${HOST}:${PORT}
# Optional comma-separated browser origins for cross-origin API access (non-dev; see config/cors.ts)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Better Auth
BETTER_AUTH_SECRET=5bf14dee6ea608f5da675 # CHANGE ME PLS !!!!!
REQUIRE_EMAIL_VERIFICATION=false

# Dev tools bootstrap surface (development and test only)
DEV_TOOLS_ENABLED=false
DEV_TOOLS_DESTRUCTIVE_OPERATIONS_ENABLED=false
DEV_OPERATOR_DEFAULT_NAME=Dev Operator
DEV_OPERATOR_DEFAULT_EMAIL=dev-operator@example.local
DEV_OPERATOR_DEFAULT_PASSWORD=DevOperator123!

# Demo mode
DEMO_MODE_ENABLED=false
# Required with DEMO_MODE_ENABLED when NODE_ENV=production (anonymous auth + demo seed); never enable on real customer deploys.
DEMO_PRODUCTION_FORCE=false
DEMO_COMMANDS_ENABLED=false

# Session (AdonisJS — flash messages, CSRF, transient HTTP data only)
SESSION_DRIVER=cookie

# Rate limiting
LIMITER_STORE=redis

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=accounting
DB_PASSWORD=accounting
DB_DATABASE=accounting-dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Must match the Redis password configured for the local compose stack.
REDIS_PASSWORD=redis
REDIS_MAIN_DB=0
REDIS_LIMITER_DB=1
