# Tenant mode: 'multi' (default) or 'single' (recommended for single-VPS deploy)
TENANT_MODE=multi
# SINGLE_TENANT_ORG_ID=   # required when TENANT_MODE=single

# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=5162206c63cca8cd8cb79319cf53b2f7 # CHANGE ME PLS !!!!!
APP_URL=http://${HOST}:${PORT}

# Better Auth
BETTER_AUTH_SECRET=5bf14dee6ea608f5da675 # CHANGE ME PLS !!!!!
REQUIRE_EMAIL_VERIFICATION=false

# Dev tools bootstrap (development only)
DEV_TOOLS_LOCAL_ENABLED=false
DEV_OPERATOR_DEFAULT_NAME=Dev Operator
DEV_OPERATOR_DEFAULT_EMAIL=dev-operator@example.local
DEV_OPERATOR_DEFAULT_PASSWORD=DevOperator123!
# DEV_OPERATOR_PUBLIC_IDS=   # optional legacy override for pre-authorized accounts

# Demo mode
DEMO_MODE_ENABLED=false
DEMO_COMMANDS_ENABLED=false
# DEMO_ALLOWED_TENANT_IDS=   # optional comma-separated tenant allowlist for demo:seed / demo:reset

# Session (AdonisJS — flash messages, CSRF, transient HTTP data only)
SESSION_DRIVER=cookie

# Rate limiting
LIMITER_STORE=redis

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=accounting
DB_PASSWORD=accounting
DB_DATABASE=accounting-dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Must match the Redis password configured for the local compose stack.
REDIS_PASSWORD=redis
REDIS_MAIN_DB=0
REDIS_LIMITER_DB=1
