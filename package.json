{
  "name": "accounting-app-scale-up",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prebuild": "node scripts/generate_tuyau_registry.mjs",
    "prelint": "node scripts/generate_tuyau_registry.mjs",
    "pretypecheck": "node scripts/generate_tuyau_registry.mjs",
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace migration:run && node ace serve --hmr",
    "test": "node ace test",
    "pretest:unit": "node scripts/generate_tuyau_registry.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:frontend": "vitest run --project frontend",
    "test:unit:backend": "vitest run --project backend",
    "test:routes": "node ace test routes",
    "test:functional": "node ace test routes",
    "test:integration": "node ace test integration",
    "test:browser": "node ace test browser",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project inertia/tsconfig.json",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "axios": "1.15.0",
      "brace-expansion@2.0.2": "2.0.3",
      "brace-expansion@5.0.4": "5.0.5",
      "defu": "^6.1.5",
      "esbuild": "^0.25.12",
      "flatted": "^3.4.2",
      "kysely": "^0.28.14",
      "lodash": "^4.18.0",
      "lodash-es": "^4.18.0",
      "micromatch>picomatch": "2.3.2",
      "anymatch>picomatch": "2.3.2",
      "@adonisjs/assembler>picomatch": "4.0.4",
      "@stylistic/eslint-plugin>picomatch": "4.0.4",
      "hot-hook>picomatch": "4.0.4",
      "vite>picomatch": "4.0.4",
      "yaml": "^2.8.3"
    }
  },
  "imports": {
    "#generated/*": "./.adonisjs/server/*.js",
    "#start/*": "./app/core/common/start/*.js",
    "#config/*": "./app/core/common/config/*.js",
    "#core/common/*": "./app/core/common/*.js",
    "#core/shared/*": "./app/core/shared/*.js",
    "#core/user_management/*": "./app/core/user_management/*.js",
    "#core/accounting/*": "./app/core/accounting/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/vite": "^4.1.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "hot-hook": "^1.0.0",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.0",
    "testcontainers": "^11.13.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.4",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.1.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@better-auth/drizzle-adapter": "^1.5.5",
    "@inertiajs/react": "^2.3.18",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.3.0",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.2",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "uuid": "^13.0.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}
