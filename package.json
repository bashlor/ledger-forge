{
  "name": "accounting-app-scale-up",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prebuild": "node scripts/generate_tuyau_registry.mjs",
    "prelint": "node scripts/generate_tuyau_registry.mjs",
    "pretypecheck": "node scripts/generate_tuyau_registry.mjs",
    "setup": "bash ./first-easy-start.sh",
    "start": "node bin/server.js",
    "build": "rm -rf build && NODE_ENV=production node ace build",
    "check:prod-safety": "bash ./scripts/check-production-safety.sh",
    "verify:prod-build-no-dev-tools": "node scripts/verify-prod-build-no-dev-tools.mjs",
    "postbuild": "node scripts/prune-dev-only-build-artifacts.mjs",
    "dev": "node ace migration:run && node ace serve --hmr",
    "services:up": "bash ./scripts/services.sh up",
    "services:down": "bash ./scripts/services.sh down",
    "db:up": "bash ./scripts/services.sh up postgres",
    "db:down": "bash ./scripts/services.sh down postgres",
    "test": "bash ./scripts/run-ace-test.sh",
    "test:backend": "bash ./scripts/run-ace-test.sh",
    "pretest:unit": "node scripts/generate_tuyau_registry.mjs",
    "test:unit:frontend": "vitest",
    "test:unit:backend": "bash ./scripts/run-ace-test.sh unit",
    "test:routes": "bash ./scripts/run-ace-test.sh routes",
    "test:functional": "bash ./scripts/run-ace-test.sh routes",
    "test:integration": "bash ./scripts/run-ace-test.sh integration",
    "test:browser": "bash ./scripts/run-ace-test.sh browser",
    "test:browser:ui": "bash ./scripts/run-ace-test.sh browser --ui",
    "test:browser:report": "bash ./scripts/run-ace-test.sh browser --report",
    "test:e2e": "bash ./scripts/run-ace-test.sh browser",
    "test:e2e:ui": "bash ./scripts/run-ace-test.sh browser --ui",
    "test:e2e:report": "bash ./scripts/run-ace-test.sh browser --report",
    "test:console": "bash ./scripts/run-ace-test.sh console",
    "playwright:install": "pnpm exec playwright install chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit --project inertia/tsconfig.json",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "@adonisjs/http-server": "^8.2.0",
      "brace-expansion@2.0.2": "2.0.3",
      "brace-expansion@5.0.4": "5.0.5",
      "dockerode@4.0.10": "5.0.0",
      "esbuild@0.18.20": "0.27.7",
      "lodash-es@4.17.23": "4.18.1",
      "postcss@8.5.9": "8.5.10",
      "protobufjs@7.5.4": "7.5.5"
    }
  },
  "imports": {
    "#generated/*": "./.adonisjs/server/*.js",
    "#start/*": "./app/core/common/start/*.js",
    "#config/*": "./app/core/common/config/*.js",
    "#core/common/*": "./app/core/common/*.js",
    "#core/shared/*": "./app/core/shared/*.js",
    "#core/user_management/*": "./app/core/user_management/*.js",
    "#core/dev_tools/*": "./app/core/dev_tools/*.js",
    "#core/accounting/*": "./app/core/accounting/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "hot-hook": "^1.0.0",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "testcontainers": "^11.14.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@inertiajs/react": "^2.3.21",
    "@radix-ui/react-select": "^2.2.6",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.3.1",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "uuid": "^14.0.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}
