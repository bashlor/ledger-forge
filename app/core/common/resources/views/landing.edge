<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Ledger Forge is a production-minded accounting demo built to showcase backend engineering skills."
    />
    <title>Ledger Forge - Backend Portfolio Project</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    @vite(['inertia/css/tailwind.css'], { nonce: cspNonce })
    <style nonce="{{ cspNonce }}">
      @keyframes landing-rise {
        from {
          opacity: 0;
          transform: translate3d(0, 18px, 0);
        }
        to {
          opacity: 1;
          transform: translate3d(0, 0, 0);
        }
      }

      .landing-rise {
        animation: landing-rise 720ms cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .landing-delay-1 {
        animation-delay: 90ms;
      }

      .landing-delay-2 {
        animation-delay: 180ms;
      }

      .landing-delay-3 {
        animation-delay: 270ms;
      }

      .screenshot-depth {
        box-shadow:
          0 34px 86px rgba(15, 23, 42, 0.14),
          0 2px 10px rgba(15, 23, 42, 0.08);
      }

      .landing-screen {
        overflow: hidden;
        border: 1px solid rgba(203, 213, 225, 0.9);
        border-radius: 0.75rem;
        background: white;
      }

      .landing-screen img {
        display: block;
        width: 100%;
        height: auto;
        max-height: none;
      }

      /* Hero screenshot: avoid clipping translated shadow / full aspect ratio */
      .landing-hero-screen {
        overflow: visible;
      }

      .landing-hero-screen img {
        border-radius: 0.75rem;
        border: 1px solid rgba(203, 213, 225, 0.9);
        box-sizing: border-box;
      }

      .showcase-screen {
        max-width: 56rem;
      }

      @media (prefers-reduced-motion: reduce) {
        .landing-rise {
          animation: none;
        }
      }
    </style>
  </head>
  <body class="bg-[#f8f6f0] text-slate-950 antialiased">
    <header class="absolute inset-x-0 top-0 z-20">
      <nav
        class="mx-auto flex max-w-7xl items-center justify-between px-5 py-5 sm:px-8"
        aria-label="Public navigation"
      >
        <a href="/" class="text-sm font-extrabold tracking-[0.18em] text-slate-950 uppercase">
          Ledger Forge
        </a>
        <div class="flex items-center gap-3 text-sm font-semibold">
          <a
            href="https://github.com/bashlor/ledger-forge"
            class="hidden text-slate-700 transition hover:text-indigo-700 sm:inline"
          >
            Source
          </a>
          <a
            href="/signin"
            class="rounded-md bg-slate-950 px-4 py-2 text-white shadow-sm transition duration-200 hover:-translate-y-0.5 hover:bg-indigo-700 focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:outline-none"
          >
            Demo
          </a>
        </div>
      </nav>
    </header>

    <main>
      <section
        class="relative isolate overflow-x-clip border-b border-slate-200/80 bg-[#f8f6f0] pt-24 sm:pt-28"
      >
        <div
          class="absolute inset-x-0 top-0 -z-10 h-[50rem] bg-[radial-gradient(circle_at_74%_12%,rgba(79,70,229,0.15),transparent_30%),linear-gradient(180deg,rgba(255,255,255,0.86),rgba(248,246,240,0))]"
        ></div>
        <div class="mx-auto max-w-7xl px-5 sm:px-8">
          <div class="grid gap-10 lg:grid-cols-[0.72fr_0.28fr] lg:items-end">
            <div class="max-w-4xl">
              <p class="landing-rise text-sm font-bold tracking-[0.2em] text-indigo-700 uppercase">
                Backend portfolio project
              </p>
              <h1
                class="landing-rise landing-delay-1 mt-5 max-w-5xl text-4xl leading-[1.02] font-extrabold tracking-normal text-slate-950 sm:text-6xl lg:text-7xl"
              >
                Production-minded accounting demo built to showcase backend engineering skills.
              </h1>
              <p
                class="landing-rise landing-delay-2 mt-6 max-w-3xl text-lg leading-8 font-medium text-slate-700 sm:text-xl sm:leading-9"
              >
                A realistic business application focused on domain rules, data integrity,
                authorization, auditability, and pragmatic product execution.
              </p>
              <div class="landing-rise landing-delay-3 mt-9 flex flex-wrap gap-3">
                <a
                  href="https://github.com/bashlor/ledger-forge"
                  class="rounded-md bg-slate-950 px-5 py-3 text-sm font-bold text-white shadow-sm transition duration-200 hover:-translate-y-0.5 hover:bg-indigo-700 focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:outline-none"
                >
                  GitHub source
                </a>
                <a
                  href="/signin"
                  class="rounded-md border border-slate-300 bg-white/70 px-5 py-3 text-sm font-bold text-slate-950 transition duration-200 hover:-translate-y-0.5 hover:border-indigo-300 hover:text-indigo-700 focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:outline-none"
                >
                  Open demo
                </a>
              </div>
            </div>

            <div
              class="landing-rise landing-delay-3 hidden min-h-0 flex-col rounded-lg border border-slate-200/90 bg-white/60 p-4 shadow-sm ring-1 ring-slate-900/[0.03] lg:flex"
              aria-label="Project capability summary"
            >
              <p class="text-[11px] font-bold tracking-[0.18em] text-slate-500 uppercase">
                Review signals
              </p>
              <div class="mt-3 flex flex-wrap gap-2">
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-700">Multi-tenant</span>
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-700">RBAC</span>
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-700">Audit trail</span>
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-700">SQL constraints</span>
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-700">Tests</span>
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-700">Docker ready</span>
              </div>
            </div>
          </div>

          <div
            class="landing-rise landing-delay-3 mt-10 flex flex-wrap gap-2 lg:hidden"
            aria-label="Project capability summary"
          >
            <span class="rounded-md border border-slate-200 bg-white/80 px-2.5 py-1 text-xs font-bold text-slate-700">Multi-tenant</span>
            <span class="rounded-md border border-slate-200 bg-white/80 px-2.5 py-1 text-xs font-bold text-slate-700">RBAC</span>
            <span class="rounded-md border border-slate-200 bg-white/80 px-2.5 py-1 text-xs font-bold text-slate-700">Audit trail</span>
            <span class="rounded-md border border-slate-200 bg-white/80 px-2.5 py-1 text-xs font-bold text-slate-700">SQL constraints</span>
            <span class="rounded-md border border-slate-200 bg-white/80 px-2.5 py-1 text-xs font-bold text-slate-700">Tests</span>
            <span class="rounded-md border border-slate-200 bg-white/80 px-2.5 py-1 text-xs font-bold text-slate-700">Docker ready</span>
          </div>

          <div class="landing-rise landing-delay-3 mt-8 pb-12 sm:pb-16 lg:mt-10">
            <div class="landing-hero-screen screenshot-depth transition duration-500 hover:-translate-y-1">
              <img
                src="/images/landing/dashboard.webp"
                alt="Ledger Forge dashboard with accounting summary metrics and recent invoices"
                width="2386"
                height="1377"
                fetchpriority="high"
              />
            </div>
          </div>

        </div>
      </section>

      <section class="border-b border-slate-200 bg-white">
        <div
          class="mx-auto grid max-w-7xl gap-8 px-5 py-18 sm:px-8 lg:grid-cols-[0.92fr_1.08fr] lg:py-24"
        >
          <div>
            <p class="text-sm font-bold tracking-[0.18em] text-indigo-700 uppercase">
              Not another CRUD tutorial.
            </p>
            <h2 class="mt-4 max-w-2xl text-3xl leading-tight font-extrabold tracking-normal sm:text-5xl">
              Built around the backend decisions reviewers actually look for.
            </h2>
          </div>
          <p class="max-w-2xl text-lg leading-8 text-slate-700 lg:pt-10">
            Ledger Forge models tenant boundaries, RBAC, invoice lifecycle rules, audit trail
            failure modes, and database constraints in a compact product surface that is easy to
            inspect.
          </p>
        </div>
      </section>

      <section class="bg-[#f8f6f0]">
        <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8 lg:py-28">
          <div class="grid gap-18 lg:gap-20">
            <article class="grid items-start gap-10 lg:grid-cols-[0.72fr_1.28fr]">
              <div class="max-w-xl">
                <p class="text-sm font-bold tracking-[0.18em] text-indigo-700 uppercase">
                  Customers
                </p>
                <h2 class="mt-3 text-3xl leading-tight font-extrabold tracking-normal sm:text-4xl">
                  Tenant-scoped records with simple, inspectable workflows.
                </h2>
                <p class="mt-5 text-lg leading-8 text-slate-700">
                  The customer area keeps routine operations flat while still respecting workspace
                  boundaries, authorization checks, and deletion rules once invoices reference a
                  contact.
                </p>
              </div>
              <div class="showcase-screen justify-self-center lg:justify-self-end lg:pr-2">
                <div class="landing-screen screenshot-depth transition duration-500 hover:-translate-y-1 lg:sticky lg:top-8">
                  <img
                    src="/images/landing/customers.webp"
                    alt="Ledger Forge customers table with balances, contact details, and actions"
                    width="2441"
                    height="1573"
                    loading="lazy"
                  />
                </div>
              </div>
            </article>

            <article class="grid items-start gap-10 lg:grid-cols-[1.28fr_0.72fr]">
              <div class="order-2 showcase-screen justify-self-center lg:order-1 lg:justify-self-start lg:pl-2">
                <div class="landing-screen screenshot-depth transition duration-500 hover:-translate-y-1 lg:sticky lg:top-8">
                  <img
                    src="/images/landing/invoice-editor.webp"
                    alt="Ledger Forge invoice draft editor with line items and server-calculated totals"
                    width="2441"
                    height="1573"
                    loading="lazy"
                  />
                </div>
              </div>
              <div class="order-1 max-w-xl lg:order-2 lg:justify-self-end">
                <p class="text-sm font-bold tracking-[0.18em] text-indigo-700 uppercase">
                  Invoices
                </p>
                <h2 class="mt-3 text-3xl leading-tight font-extrabold tracking-normal sm:text-4xl">
                  Domain rules where the product risk is real.
                </h2>
                <p class="mt-5 text-lg leading-8 text-slate-700">
                  Draft editing, lifecycle transitions, server-authoritative totals, and audit
                  history are handled as business behavior instead of UI state.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="border-y border-slate-200 bg-white">
        <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8 lg:py-28">
          <div class="max-w-3xl">
            <p class="text-sm font-bold tracking-[0.18em] text-indigo-700 uppercase">
              Engineering focus
            </p>
            <h2 class="mt-4 text-3xl leading-tight font-extrabold tracking-normal sm:text-5xl">
              Small surface, serious backend shape.
            </h2>
          </div>
          <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md hover:shadow-slate-900/[0.08]">
              <div class="h-1 w-10 rounded-full bg-indigo-600"></div>
              <h3 class="mt-6 text-lg font-extrabold text-slate-950">Domain rules</h3>
              <p class="mt-3 leading-7 text-slate-700">
                Invoice totals, status transitions, and mutation guards live server-side.
              </p>
            </div>
            <div class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md hover:shadow-slate-900/[0.08]">
              <div class="h-1 w-10 rounded-full bg-slate-950"></div>
              <h3 class="mt-6 text-lg font-extrabold text-slate-950">Authorization</h3>
              <p class="mt-3 leading-7 text-slate-700">
                RBAC abilities are checked in context, not inferred from routes alone.
              </p>
            </div>
            <div class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md hover:shadow-slate-900/[0.08]">
              <div class="h-1 w-10 rounded-full bg-indigo-600"></div>
              <h3 class="mt-6 text-lg font-extrabold text-slate-950">Data modeling</h3>
              <p class="mt-3 leading-7 text-slate-700">
                PostgreSQL constraints and Drizzle schemas keep tenant data explicit.
              </p>
            </div>
            <div class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md hover:shadow-slate-900/[0.08]">
              <div class="h-1 w-10 rounded-full bg-slate-950"></div>
              <h3 class="mt-6 text-lg font-extrabold text-slate-950">Reliability</h3>
              <p class="mt-3 leading-7 text-slate-700">
                Audit trail degradation blocks risky writes while preserving reads.
              </p>
            </div>
            <div class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md hover:shadow-slate-900/[0.08]">
              <div class="h-1 w-10 rounded-full bg-indigo-600"></div>
              <h3 class="mt-6 text-lg font-extrabold text-slate-950">Testing mindset</h3>
              <p class="mt-3 leading-7 text-slate-700">
                Unit, integration, route, and browser suites cover different failure modes.
              </p>
            </div>
            <div class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:shadow-md hover:shadow-slate-900/[0.08]">
              <div class="h-1 w-10 rounded-full bg-slate-950"></div>
              <h3 class="mt-6 text-lg font-extrabold text-slate-950">Product execution</h3>
              <p class="mt-3 leading-7 text-slate-700">
                The UI exists to make backend behavior visible and reviewable.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-[#f8f6f0]">
        <div class="mx-auto max-w-7xl px-5 py-20 sm:px-8 lg:py-28">
          <div class="grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
            <div>
              <p class="text-sm font-bold tracking-[0.18em] text-indigo-700 uppercase">
                Stack
              </p>
              <h2 class="mt-4 max-w-xl text-3xl leading-tight font-extrabold tracking-normal sm:text-5xl">
                TypeScript from route to database.
              </h2>
              <p class="mt-5 max-w-lg text-lg leading-8 text-slate-700">
                A compact full-stack surface built around typed server behavior, relational data,
                and inspectable UI flows.
              </p>
            </div>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">AdonisJS</span>
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">TypeScript</span>
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">PostgreSQL</span>
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">Drizzle ORM</span>
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">React</span>
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">Inertia</span>
              <span class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-extrabold text-slate-950 shadow-sm">Tailwind</span>
              <span class="rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm font-extrabold text-indigo-950 shadow-sm">Better-Auth</span>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-slate-950 text-white">
        <div
          class="mx-auto grid max-w-7xl gap-8 px-5 py-18 sm:px-8 lg:grid-cols-[1fr_auto] lg:items-center lg:py-20"
        >
          <div>
            <p class="text-sm font-bold tracking-[0.18em] text-indigo-200 uppercase">
              Review the project
            </p>
            <h2 class="mt-4 max-w-4xl text-3xl leading-tight font-extrabold tracking-normal sm:text-5xl">
              Review the architecture, inspect the code, then explore the live demo.
            </h2>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <a
              href="https://github.com/bashlor/ledger-forge"
              class="rounded-md bg-white px-5 py-3 text-sm font-bold text-slate-950 transition duration-200 hover:-translate-y-0.5 hover:bg-indigo-100 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950 focus-visible:outline-none"
            >
              GitHub source
            </a>
            <a
              href="/signin"
              class="rounded-md border border-white/20 px-5 py-3 text-sm font-bold text-white transition duration-200 hover:-translate-y-0.5 hover:border-indigo-200 hover:text-indigo-100 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950 focus-visible:outline-none"
            >
              Open demo
            </a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
