# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=test

# App
LOG_LEVEL=info
APP_KEY=037ed83987677c452bc169c88ce8c087
APP_URL=http://${HOST}:${PORT}

# Better Auth
BETTER_AUTH_SECRET=037ed83987677c452bc169c88ce8c087
REQUIRE_EMAIL_VERIFICATION=false

# Session (AdonisJS — flash messages, CSRF, transient HTTP data only)
SESSION_DRIVER=memory

# Rate limiting
LIMITER_STORE=memory

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=accounting
DB_PASSWORD=accounting
DB_DATABASE=accounting-test

# Testcontainers
POSTGRES_TEST_IMAGE=postgres:17-alpine
